# TurbineGuard application settings.
#
# Copy this file to `.env` and adjust values as needed. Every variable is
# optional; the values below are the application defaults. Real `.env` files
# are gitignored and must never be committed.

# Human-readable application name.
TURBINE_GUARD_APP_NAME=turbine-guard

# Deployment environment: development, testing, or production.
TURBINE_GUARD_ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, or CRITICAL (case-insensitive).
TURBINE_GUARD_LOG_LEVEL=INFO
