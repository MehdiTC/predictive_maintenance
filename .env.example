# TurbineGuard application settings.
#
# Copy this file to `.env` and adjust values as needed. Every variable is
# optional; the values below are the application defaults. Real `.env` files
# are gitignored and must never be committed.

# Human-readable application name.
TURBINE_GUARD_APP_NAME=turbine-guard

# Deployment environment: development, testing, or production.
TURBINE_GUARD_ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, or CRITICAL (case-insensitive).
TURBINE_GUARD_LOG_LEVEL=INFO

# Base directory for the data layers (raw, manifests, ...). Gitignored.
TURBINE_GUARD_DATA_DIR=data

# Source archive for the NASA C-MAPSS dataset. Accepts https:// or file://
# (useful for mirrors or a pre-downloaded archive if NASA hosting moves).
TURBINE_GUARD_CMAPSS_SOURCE_URL=https://phm-datasets.s3.amazonaws.com/NASA/6.+Turbofan+Engine+Degradation+Simulation+Data+Set.zip

# Loop 5 MLflow tracking and registry. SQLite supports the local registry;
# artifacts remain local and gitignored. Remote HTTP(S) URIs can replace these.
TURBINE_GUARD_MLFLOW_TRACKING_URI=sqlite:///data/mlflow/mlflow.db
TURBINE_GUARD_MLFLOW_EXPERIMENT_NAME=TurbineGuard-FD001-Offline-Modeling
TURBINE_GUARD_MLFLOW_REGISTERED_MODEL_NAME=TurbineGuard-FD001-RUL
TURBINE_GUARD_MLFLOW_ARTIFACT_LOCATION=data/mlflow/artifacts
TURBINE_GUARD_MLFLOW_REGISTRATION_ENABLED=true
TURBINE_GUARD_MLFLOW_PROMOTE_CHAMPION=true
TURBINE_GUARD_MLFLOW_CANDIDATE_ALIAS=candidate
TURBINE_GUARD_MLFLOW_CHALLENGER_ALIAS=challenger
TURBINE_GUARD_MLFLOW_CHAMPION_ALIAS=champion
TURBINE_GUARD_MLFLOW_ARCHIVED_ALIAS=archived
TURBINE_GUARD_MLFLOW_RUN_NAME_PREFIX=fd001-offline
TURBINE_GUARD_MLFLOW_PROJECT_TAG=turbine-guard

# Loop 6 operational PostgreSQL. This is independent from MLflow's SQLite metadata.
# Replace placeholders locally; never commit real credentials.
TURBINE_GUARD_DATABASE_URL=postgresql+psycopg://turbine_guard:change-me@localhost:5432/turbine_guard
# Integration tests are destructive and require a separate database whose name contains "test".
TURBINE_GUARD_DATABASE_TEST_URL=postgresql+psycopg://turbine_guard:change-me@localhost:5432/turbine_guard_test
TURBINE_GUARD_DATABASE_POOL_SIZE=5
TURBINE_GUARD_DATABASE_MAX_OVERFLOW=10
TURBINE_GUARD_DATABASE_POOL_TIMEOUT_SECONDS=30
TURBINE_GUARD_DATABASE_POOL_RECYCLE_SECONDS=1800
TURBINE_GUARD_DATABASE_CONNECT_TIMEOUT_SECONDS=5
TURBINE_GUARD_DATABASE_STATEMENT_TIMEOUT_MS=30000
TURBINE_GUARD_DATABASE_ECHO=false

# Loop 7 online API and model lifecycle.
TURBINE_GUARD_ONLINE_INFERENCE_ENABLED=true
TURBINE_GUARD_MODEL_PRELOAD_ENABLED=true
TURBINE_GUARD_ASSET_STALE_AFTER_SECONDS=300
TURBINE_GUARD_API_DEFAULT_PAGE_SIZE=50
TURBINE_GUARD_API_MAX_PAGE_SIZE=200
TURBINE_GUARD_API_PREDICTION_TREND_SIZE=20
TURBINE_GUARD_API_MAX_REQUEST_BYTES=1048576
TURBINE_GUARD_API_DOCS_ENABLED=true
# JSON arrays. Empty CORS is restrictive; add explicit origins only when needed.
TURBINE_GUARD_CORS_ALLOWED_ORIGINS=[]
TURBINE_GUARD_TRUSTED_HOSTS=["localhost","127.0.0.1","testserver"]
