# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Tool caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Environment files (never commit real configuration or secrets)
.env
.env.*
!.env.example

# Data layers at the repository root (datasets and acquisition artifacts are
# reproducible via scripts/download_data.py; never commit them)
/data/

# Alternate local MLflow defaults when configured outside data/
/mlruns/
/mlartifacts/
/mlflow.db
/mlflow.db-shm
/mlflow.db-wal

# Local PostgreSQL dumps and ad-hoc database exports
/db-dumps/
/*.dump
/*.backup

# Internal / non-public files (kept locally, excluded from the public repo)
# CLAUDE.md is the local agent operating manual and references a prior engagement.
/CLAUDE.md
# Internal build/process scaffolding; recruiters get the public README + docs/.
# PROJECT_SPEC.md also references a prior engagement.
/PROJECT_SPEC.md
/STATUS.md
/TASKS.md
# Accidentally-committed personal Claude Code skill; not part of the project.
.github/skills/

# Notebooks
.ipynb_checkpoints/

# Editors and OS
.DS_Store
.idea/
.vscode/
